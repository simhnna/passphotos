<!doctype html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <title>Biometrische Bilder - Lizenzen</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
    />
    <link rel="stylesheet" href="style.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
        rel="icon"
        type="image/png"
        sizes="32x32"
        href="/assets/favicon/favicon-32x32.png"
    />
    <link
        rel="icon"
        type="image/png"
        sizes="16x16"
        href="/assets/favicon/favicon-16x16.png"
    />
    <link rel="manifest" href="/assets/favicon/site.webmanifest" />
    <style>
        .licenses-list {
            list-style-type: none;
            margin: 0;
            padding: 0;
        }

        .license-used-by {
            margin-top: -10px;
        }

        .license-text {
            max-height: 200px;
            overflow-y: scroll;
            white-space: pre-wrap;
            font-family: monospace;
            font-size: 0.85rem;
            background: var(--color-controls-bg);
            padding: 12px;
            border-radius: 4px;
            border: 1px solid var(--color-card-border);
        }

        .intro {
            text-align: center;
            margin-bottom: 32px;
        }

        .intro h1 {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        .intro p {
            margin: 8px 0 0;
            color: var(--color-text-muted);
        }

        .license {
            margin-bottom: 32px;
            padding-bottom: 32px;
            border-bottom: 1px solid var(--color-card-border);
        }

        .license:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .license h3 {
            margin: 0 0 8px;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .license h4 {
            margin: 16px 0 8px;
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--color-text-muted);
        }

        .licenses-overview {
            margin-bottom: 32px;
        }

        .licenses-overview li {
            margin-bottom: 8px;
        }
    </style>
</head>

<body>
    <header>
        <div class="header-inner">
            <h1>Biometrische Bilder erstellen</h1>
            <p class="header-subtitle">Lizenzen und Abhängigkeiten</p>
        </div>
    </header>
    <main>
        <div class="intro">
            <a href="/">
                <h1>Biometrische Bilder erstellen</h1>
            </a>
            <p>Diese Seite listet die Lizenzen der verwendeten Projekte auf.</p>
        </div>

        <h2>Lizenz-Übersicht:</h2>
        <ul class="licenses-overview">
            {{#each overview}}
            <li><a href="#{{id}}">{{name}}</a> ({{count}})</li>
            {{/each}}
        </ul>

        <h2>Alle Lizenztexte:</h2>
        <ul class="licenses-list">
            {{#each licenses}}
            <li class="license">
                <h3 id="{{id}}">{{name}}</h3>
                <h4>Verwendet von:</h4>
                <ul class="license-used-by">
                    {{#each used_by}}
                    <li><a href="{{#if crate.repository}} {{crate.repository}} {{else}} https://crates.io/crates/{{crate.name}} {{/if}}">{{crate.name}} {{crate.version}}</a></li>
                    {{/each}}
                </ul>
                <pre class="license-text">{{text}}</pre>
            </li>
            {{/each}}
        </ul>

        <div class="intro">
            <h1>Weitere verwendete Komponenten</h1>
            <p>
                <a href="https://github.com/Cool-Runningz/range-input.css">Range Input CSS</a>
            </p>
            <p>
                <a href="https://copy-paste-css.com/">Button Styles</a>
            </p>
            <p>
                <a href="https://github.com/EmbarkStudios/cargo-about">cargo-about</a>
            </p>
        </div>
    </main>
    <footer>
        <a href="https://github.com/simhnna/passphotos">Source</a> |
        <a href="/licence.html">Licences</a>
    </footer>
</body>

</html>
